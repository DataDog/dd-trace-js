# http://editorconfig.org

root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.avro]
charset = unset
end_of_line = unset
insert_final_newline = unset

# TODO: fix OpenAI tests
[packages/datadog-plugin-openai/test/fine-tune.jsonl]
insert_final_newline = unset

# Streamed verbatim and asserted byte-for-byte by the response-blocking test.
[packages/dd-trace/test/appsec/streamtest.txt]
insert_final_newline = false

# CRLF so the license workflow's `cat vendored-dependencies.csv >> LICENSE-3rdparty.csv`
# append stays byte-stable; otherwise editors re-LF on save and the release tooling re-commits.
[LICENSE-3rdparty.csv]
end_of_line = crlf

[.github/vendored-dependencies.csv]
end_of_line = crlf
