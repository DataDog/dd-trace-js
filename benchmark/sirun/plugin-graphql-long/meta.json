{
  "name": "plugin-graphql-long",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "iterations": 10,
  "instructions": true,
  "variants": {
    "with-depth-off": {
      "iterations": 7,
      "env": { "WITH_TRACER": "1", "WITH_DEPTH": "0", "OPERATIONS": "1150" }
    },
    "with-depth-on-max": {
      "env": { "WITH_TRACER": "1", "WITH_DEPTH": "4", "OPERATIONS": "530" }
    },
    "with-depth-and-collapse-off": {
      "env": { "WITH_TRACER": "1", "WITH_DEPTH_AND_COLLAPSE": "4,0", "OPERATIONS": "210" }
    }
  }
}
