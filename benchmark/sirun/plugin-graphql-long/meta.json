{
  "name": "plugin-graphql-long",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "iterations": 10,
  "instructions": true,
  "variants": {
    "with-depth-off": {
      "iterations": 7,
      "env": {
        "DEPTH": "0",
        "OPERATIONS": "1150",
        "WITH_TRACER": "1"
      }
    },
    "with-depth-on-max": {
      "env": {
        "COLLAPSE": "1",
        "OPERATIONS": "800",
        "DEPTH": "10",
        "WITH_TRACER": "1"
      }
    },
    "with-depth-and-collapse-off": {
      "env": {
        "COLLAPSE": "0",
        "OPERATIONS": "300",
        "DEPTH": "10",
        "WITH_TRACER": "1"
      }
    }
  }
}
