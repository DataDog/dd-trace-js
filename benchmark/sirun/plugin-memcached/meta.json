{
  "name": "plugin-memcached",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "iterations": 12,
  "instructions": true,
  "variants": {
    "get": {
      "env": { "VARIANT": "get", "ITERATIONS": "120000000" }
    },
    "hashring": {
      "env": { "VARIANT": "hashring", "ITERATIONS": "120000000" }
    }
  }
}
