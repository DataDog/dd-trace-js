{
  "name": "encoders",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "instructions": true,
  "iterations": 10,
  "variants": {
    "0.4": {
      "env": {
        "ENCODER_VERSION": "0.4",
        "WITH_SPAN_EVENTS": "none"
      }
    },
    "0.5": {
      "env": {
        "ENCODER_VERSION": "0.5",
        "WITH_SPAN_EVENTS": "none"
      }
    },
    "0.4-events-native": {
      "env": {
        "ENCODER_VERSION": "0.4",
        "WITH_SPAN_EVENTS": "native",
        "DD_TRACE_NATIVE_SPAN_EVENTS": "true"
      }
    },
    "0.4-events-legacy": {
      "env": {
        "ENCODER_VERSION": "0.4",
        "WITH_SPAN_EVENTS": "legacy",
        "DD_TRACE_NATIVE_SPAN_EVENTS": "false"
      }
    },
    "0.5-events-legacy": {
      "env": {
        "ENCODER_VERSION": "0.5",
        "WITH_SPAN_EVENTS": "legacy"
      }
    },
    "0.4-wide-tags": {
      "env": {
        "ENCODER_VERSION": "0.4",
        "WITH_SPAN_EVENTS": "none",
        "WIDE_TAGS": "40",
        "ENCODE_COUNT": "12000"
      }
    },
    "0.5-wide-tags": {
      "env": {
        "ENCODER_VERSION": "0.5",
        "WITH_SPAN_EVENTS": "none",
        "WIDE_TAGS": "40",
        "ENCODE_COUNT": "16000"
      }
    }
  }
}
