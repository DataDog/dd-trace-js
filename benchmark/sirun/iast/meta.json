{
  "name": "iast",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "iterations": 12,
  "instructions": true,
  "variants": {
    "request-lifecycle": {
      "env": { "VARIANT": "request-lifecycle", "OPERATIONS": "8000" }
    },
    "sink-check": {
      "env": { "VARIANT": "sink-check", "OPERATIONS": "5000000" }
    }
  }
}
