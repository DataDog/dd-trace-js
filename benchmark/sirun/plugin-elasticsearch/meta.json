{
  "name": "plugin-elasticsearch",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "iterations": 12,
  "instructions": true,
  "variants": {
    "search": {
      "env": { "VARIANT": "search", "ITERATIONS": "2000000" }
    },
    "bulk-index": {
      "env": { "VARIANT": "bulk-index", "ITERATIONS": "600000" }
    },
    "get": {
      "env": { "VARIANT": "get", "ITERATIONS": "8000000" }
    }
  }
}
