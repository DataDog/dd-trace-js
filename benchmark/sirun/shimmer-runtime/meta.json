{
  "name": "shimmer-runtime",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "iterations": 10,
  "instructions": true,
  "variants": {
    "declared-wrap": {
      "env": {
        "WRAP_FUNCTION": "false",
        "OPERATIONS": "1000000000"
      }
    },
    "declared-wrapfn": {
      "env": {
        "WRAP_FUNCTION": "true",
        "OPERATIONS": "1000000000"
      }
    }
  }
}
