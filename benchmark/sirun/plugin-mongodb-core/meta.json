{
  "name": "plugin-mongodb-core",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "iterations": 12,
  "instructions": true,
  "variants": {
    "plain-find": {
      "env": { "VARIANT": "plain-find", "OPERATIONS": "8200000" }
    },
    "deep-aggregate": {
      "env": { "VARIANT": "deep-aggregate", "OPERATIONS": "1170000" }
    },
    "bigint-id": {
      "env": { "VARIANT": "bigint-id", "OPERATIONS": "5500000" }
    },
    "binary-hash": {
      "env": { "VARIANT": "binary-hash", "OPERATIONS": "4500000" }
    },
    "mixed-ops": {
      "env": { "VARIANT": "mixed-ops", "OPERATIONS": "5000000" }
    }
  }
}
