{
  "name": "plugin-ws",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "iterations": 15,
  "instructions": true,
  "variants": {
    "send": {
      "env": { "VARIANT": "send", "OPERATIONS": "6000000" }
    },
    "receive": {
      "env": { "VARIANT": "receive", "OPERATIONS": "6000000" }
    }
  }
}
