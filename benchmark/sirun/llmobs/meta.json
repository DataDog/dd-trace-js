{
  "name": "llmobs",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "iterations": 30,
  "instructions": true,
  "variants": {
    "encode-unicode-ascii": { "env": { "VARIANT": "encode-unicode-ascii" } },
    "encode-unicode-mixed": { "baseline": "encode-unicode-ascii", "env": { "VARIANT": "encode-unicode-mixed" } }
  }
}
