{
  "name": "profiler",
  "run": "node -r ../monitor index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node -r ../monitor index.js\"",
  "cachegrind": false,
  "iterations": 5,
  "instructions": true,
  "variants": {
    "control": {
      "env": {
        "PROFILER": "",
        "OPERATIONS": "32000"
      }
    },
    "with-cpu-profiler": {
      "env": {
        "PROFILER": "wall",
        "OPERATIONS": "32000"
      }
    },
    "with-space-profiler": {
      "env": {
        "PROFILER": "space",
        "OPERATIONS": "32000"
      }
    },
    "with-all-profilers": {
      "env": {
        "PROFILER": "all",
        "OPERATIONS": "32000"
      }
    }
  }
}
