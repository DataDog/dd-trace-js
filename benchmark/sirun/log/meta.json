{
  "name": "log",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "iterations": 10,
  "instructions": true,
  "variants": {
    "without-log": { "env": { "DD_TRACE_DEBUG": "false", "COUNT": "200000000" } },
    "skip-log": { "env": { "DD_TRACE_DEBUG": "true", "WITH_LEVEL": "debug", "DD_TRACE_LOG_LEVEL": "error", "COUNT": "200000000" } },
    "with-debug": { "env": { "DD_TRACE_DEBUG": "true", "WITH_LEVEL": "debug", "DD_TRACE_LOG_LEVEL": "debug", "COUNT": "3000000" } },
    "with-error": { "env": { "DD_TRACE_DEBUG": "true", "WITH_LEVEL": "error", "DD_TRACE_LOG_LEVEL": "error", "COUNT": "1000000" } }
  }
}
