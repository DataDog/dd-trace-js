{
  "name": "test-optimization",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "iterations": 12,
  "instructions": true,
  "variants": {
    "small-suite": {
      "env": { "VARIANT": "small-suite", "OPERATIONS": "20000" }
    },
    "large-suite": {
      "env": { "VARIANT": "large-suite", "OPERATIONS": "2400" }
    },
    "wide-tags": {
      "env": { "VARIANT": "wide-tags", "OPERATIONS": "6000" }
    }
  }
}
