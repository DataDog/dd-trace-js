{
  "name": "plugin-redis",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "iterations": 30,
  "instructions": true,
  "variants": {
    "mixed-commands": { "env": { "VARIANT": "mixed-commands" } },
    "long-args": {
      "baseline": "mixed-commands",
      "env": { "VARIANT": "long-args" }
    }
  }
}
