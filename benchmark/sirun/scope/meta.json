{
  "name": "scope-manager",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "iterations": 10,
  "instructions": true,
  "variants": {
    "base": {
      "env": {
        "COUNT": "100000000"
      }
    },
    "scope_enabled": {
      "env": {
        "SCOPE_ENABLED": "true",
        "COUNT": "8000000"
      }
    },
    "bind": {
      "env": {
        "MODE": "bind",
        "COUNT": "3000000"
      }
    }
  }
}
