{
  "name": "scope-manager",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "iterations": 10,
  "instructions": true,
  "variants": {
    "base": {
      "env": {
        "COUNT": "250000"
      }
    },
    "scope_enabled": {
      "baseline": "base",
      "env": {
        "SCOPE_ENABLED": "true",
        "COUNT": "250000"
      }
    }
  }
}
