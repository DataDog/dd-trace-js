{
  "name": "plugin-pg",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "iterations": 10,
  "instructions": true,
  "variants": {
    "service": {
      "env": { "VARIANT": "service", "OPERATIONS": "6000000" }
    },
    "full": {
      "env": { "VARIANT": "full", "OPERATIONS": "6000000" }
    }
  }
}
