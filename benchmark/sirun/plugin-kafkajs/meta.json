{
  "name": "plugin-kafkajs",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "iterations": 15,
  "instructions": true,
  "variants": {
    "small": {
      "env": { "VARIANT": "small", "OPERATIONS": "8500000" }
    },
    "large": {
      "env": { "VARIANT": "large", "OPERATIONS": "5500000" }
    },
    "mixed": {
      "env": { "VARIANT": "mixed", "OPERATIONS": "7000000" }
    }
  }
}
