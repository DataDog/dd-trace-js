{
  "name": "exporting-pipeline",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "iterations": 20,
  "instructions": true,
  "cachegrind": false,
  "variants": {
    "format": {
      "env": {
        "WITH_STATS": "0",
        "COUNT": "200000"
      }
    },
    "format-with-stats": {
      "env": {
        "WITH_STATS": "1",
        "COUNT": "200000"
      }
    },
    "format-with-links-events": {
      "env": {
        "WITH_STATS": "0",
        "WITH_LINKS": "1",
        "COUNT": "85000"
      }
    }
  }
}
