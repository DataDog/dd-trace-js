{
  "name": "openfeature",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "iterations": 10,
  "instructions": true,
  "variants": {
    "flag-eval-hook": {
      "env": {
        "VARIANT": "flag-eval-hook",
        "COUNT": "12000000"
      }
    },
    "aggregate": {
      "env": {
        "VARIANT": "aggregate",
        "COUNT": "1000000"
      }
    }
  }
}
