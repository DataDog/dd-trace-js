{
  "name": "child_process",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "iterations": 15,
  "instructions": true,
  "variants": {
    "shell-string": {
      "env": { "VARIANT": "shell-string", "ITERATIONS": "4700000" }
    },
    "file-args": {
      "env": { "VARIANT": "file-args", "ITERATIONS": "3750000" }
    }
  }
}
