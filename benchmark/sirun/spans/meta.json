{
  "name": "spans",
  "run": "node spans.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node spans.js\"",
  "cachegrind": false,
  "iterations": 12,
  "instructions": true,
  "variants": {
    "finish-immediately": {
      "env": {
        "DD_TRACE_SCOPE": "noop",
        "FINISH": "now",
        "COUNT": "2000000"
      }
    },
    "finish-later": {
      "env": {
        "DD_TRACE_SCOPE": "noop",
        "FINISH": "later",
        "COUNT": "2000000"
      }
    },
    "finish-immediately-with-tags": {
      "env": {
        "DD_TRACE_SCOPE": "noop",
        "FINISH": "now",
        "SHAPE": "tags",
        "COUNT": "2000000"
      }
    },
    "finish-immediately-with-many-tags": {
      "env": {
        "DD_TRACE_SCOPE": "noop",
        "FINISH": "now",
        "SHAPE": "many-tags",
        "COUNT": "2000000"
      }
    },
    "finish-immediately-with-tags-and-otel": {
      "env": {
        "DD_TRACE_SCOPE": "noop",
        "FINISH": "now",
        "SHAPE": "tags-and-otel",
        "COUNT": "2000000"
      }
    }
  }
}
