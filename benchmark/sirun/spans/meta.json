{
  "name": "spans",
  "run": "node spans.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node spans.js\"",
  "cachegrind": false,
  "iterations": 80,
  "instructions": true,
  "variants": {
    "finish-immediately": {
      "env": {
        "DD_TRACE_SCOPE": "noop",
        "FINISH": "now"
      }
    },
    "finish-later": {
      "env": {
        "DD_TRACE_SCOPE": "noop",
        "FINISH": "later"
      }
    },
    "finish-immediately-with-tags": {
      "baseline": "finish-immediately",
      "env": {
        "DD_TRACE_SCOPE": "noop",
        "FINISH": "now",
        "SHAPE": "tags"
      }
    },
    "finish-immediately-with-tags-and-otel": {
      "baseline": "finish-immediately",
      "env": {
        "DD_TRACE_SCOPE": "noop",
        "FINISH": "now",
        "SHAPE": "tags-and-otel"
      }
    }
  }
}
