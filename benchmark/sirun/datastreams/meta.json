{
  "name": "datastreams",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "iterations": 20,
  "instructions": true,
  "variants": {
    "produce": { "env": { "VARIANT": "produce", "ITERATIONS": "1200000" } },
    "consume": { "env": { "VARIANT": "consume", "ITERATIONS": "1200000" } },
    "produce-with-message-size": { "env": { "VARIANT": "produce-with-message-size", "ITERATIONS": "1200000" } },
    "produce-manual-checkpoint": { "env": { "VARIANT": "produce-manual-checkpoint", "ITERATIONS": "1200000" } },
    "produce-high-cardinality": { "env": { "VARIANT": "produce-high-cardinality", "ITERATIONS": "1200000" } }
  }
}
