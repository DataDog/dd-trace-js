{
  "name": "span-format",
  "run": "node index.js",
  "run_with_affinity": "bash -c \"taskset -c $CPU_AFFINITY node index.js\"",
  "cachegrind": false,
  "iterations": 12,
  "instructions": true,
  "variants": {
    "flat-tags": {
      "env": { "VARIANT": "flat-tags", "OPERATIONS": "3000000" }
    },
    "many-tags": {
      "env": { "VARIANT": "many-tags", "OPERATIONS": "900000" }
    },
    "error": {
      "env": { "VARIANT": "error", "OPERATIONS": "2000000" }
    },
    "http-server": {
      "env": { "VARIANT": "http-server", "OPERATIONS": "3000000" }
    }
  }
}
